<?xml version="1.0" encoding="UTF-8"?>
<code_scheme name="PSR12+" version="173">
    <!-- PHP-specific options -->
    <PHPCodeStyleSettings
        LOWER_CASE_KEYWORDS="true"
        LOWER_CASE_CONSTANTS="true"
        FORCE_SHORT_DECLARATION_ARRAY_STYLE="true"
        SPACE_AFTER_NULLABLE_TYPE="false"
        ALIGN_PHPDOC_PARAM_NAMES="true"
        KEEP_RPAREN_AND_LBRACE_ON_ONE_LINE="false"
    />

    <!-- Core PHP code style block -->
    <codeStyleSettings language="PHP">
        <!-- margins / visual guides -->
        <option name="RIGHT_MARGIN" value="120" />
        <option name="WRAP_WHEN_TYPING_REACHES_RIGHT_MARGIN" value="true" />
        <option name="VISUAL_GUIDE" value="120" />

        <!-- blank lines -->
        <option name="KEEP_LINE_BREAKS" value="true" />
        <option name="KEEP_FIRST_COLUMN_COMMENT" value="false" />
        <option name="KEEP_BLANK_LINES_IN_DECLARATIONS" value="1" />
        <option name="KEEP_BLANK_LINES_IN_CODE" value="1" />
        <option name="KEEP_BLANK_LINES_BEFORE_RBRACE" value="0" />

        <!-- allow simple one-line constructs -->
        <option name="KEEP_SIMPLE_METHODS_IN_ONE_LINE" value="true" />
        <option name="KEEP_SIMPLE_CLASSES_IN_ONE_LINE" value="true" />
        <option name="KEEP_SIMPLE_LAMBDAS_IN_ONE_LINE" value="true" />
        <option name="KEEP_SIMPLE_BLOCKS_IN_ONE_LINE" value="true" />

        <!-- braces / control statements (PSR-12 style) -->
        <option name="ELSE_ON_NEW_LINE" value="true" />
        <option name="WHILE_ON_NEW_LINE" value="true" />
        <option name="CATCH_ON_NEW_LINE" value="true" />
        <option name="FINALLY_ON_NEW_LINE" value="true" />

        <!-- spacing around operators -->
        <option name="SPACE_AROUND_ASSIGNMENT_OPERATORS" value="true" />
        <option name="SPACE_AROUND_LOGICAL_OPERATORS" value="true" />
        <option name="SPACE_AROUND_EQUALITY_OPERATORS" value="true" />
        <option name="SPACE_AROUND_RELATIONAL_OPERATORS" value="true" />
        <option name="SPACE_AROUND_ADDITIVE_OPERATORS" value="true" />
        <option name="SPACE_AROUND_MULTIPLICATIVE_OPERATORS" value="true" />

        <!-- space before parentheses for control structures -->
        <option name="SPACE_BEFORE_IF_PARENTHESES" value="false" />
        <option name="SPACE_BEFORE_FOR_PARENTHESES" value="false" />
        <option name="SPACE_BEFORE_WHILE_PARENTHESES" value="false" />
        <option name="SPACE_BEFORE_SWITCH_PARENTHESES" value="false" />
        <option name="SPACE_BEFORE_CATCH_PARENTHESES" value="false" />

        <!-- parameters/arguments wrapping -->
        <option name="CALL_PARAMETERS_WRAP" value="1" />
        <option name="METHOD_PARAMETERS_WRAP" value="1" />
        <option name="METHOD_CALL_ARGUMENTS_WRAP" value="1" />

        <!-- array initializer / alignment settings available in PhpStorm -->
        <option name="ARRAY_INITIALIZER_WRAP" value="1" />
        <option name="ARRAY_INITIALIZER_LBRACE_ON_NEXT_LINE" value="false" />
        <option name="ARRAY_INITIALIZER_RBRACE_ON_NEXT_LINE" value="false" />
        <option name="ALIGN_MULTILINE_ARRAY_INITIALIZER_EXPRESSION" value="true" />
        <option name="ALIGN_MULTILINE_PARAMETERS" value="true" />

        <!-- trailing comma support when multiline (PhpStorm respects where possible) -->
        <option name="ADD_TRAILING_COMMA_IN_MULTI_LINE_ARRAYS" value="true" />

        <!-- blank lines between members -->
        <option name="BLANK_LINES_AROUND_METHOD_IN_INTERFACE" value="1" />
        <option name="BLANK_LINES_AROUND_METHOD" value="1" />

        <!-- indents -->
        <indentOptions>
            <option name="INDENT_SIZE" value="4" />
            <option name="TAB_SIZE" value="4" />
            <option name="CONTINUATION_INDENT_SIZE" value="8" />
        </indentOptions>
    </codeStyleSettings>

    <!-- PHPDoc settings -->
    <codeStyleSettings language="PHP_DOC">
        <option name="ALIGN_TAGS" value="true" />
        <option name="ALIGN_PARAMETER_NAMES" value="true" />
        <option name="KEEP_FIRST_COLUMN_COMMENT" value="false" />
    </codeStyleSettings>
</code_scheme>
